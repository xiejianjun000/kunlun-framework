{
  "name": "open-taiji",
  "version": "1.0.0",
  "description": "OpenTaiji - 开源多智能体框架（OpenCLAW + Hermes + Claude Code整合）",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "docs": "typedoc src/index.ts --out docs",
    "prepare": "husky install"
  },
  "keywords": [
    "Taiji",
    "multi-agent",
    "openclaw",
    "hermes",
    "claude-code",
    "ai-framework",
    "multi-tenant",
    "skill-system",
    "memory-system"
  ],
  "author": "OpenTaiji团队",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/open-taiji/open-taiji.git"
  },
  "bugs": {
    "url": "https://github.com/xiejianjun000/open-taiji/issues"
  },
  "homepage": "https://open-taiji.dev",
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "uuid": "^13.0.0"
  }
}
