{
  "name": "kunlun-framework",
  "version": "1.0.0",
  "description": "昆仑框架 - 开源多智能体框架（OpenCLAW + Hermes + Claude Code整合）",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "docs": "typedoc src/index.ts --out docs",
    "prepare": "husky install"
  },
  "keywords": [
    "kunlun",
    "multi-agent",
    "openclaw",
    "hermes",
    "claude-code",
    "ai-framework",
    "multi-tenant",
    "skill-system",
    "memory-system"
  ],
  "author": "昆仑框架团队",
  "license": "Apache-2.0",
  "dependencies": {
    "@qdrant/js-client-rest": "^1.7.0",
    "ioredis": "^5.3.2",
    "kafkajs": "^2.2.4",
    "neo4j-driver": "^5.18.0",
    "pg": "^8.11.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.16",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "eslint": "^8.56.0",
    "husky": "^9.0.10",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typedoc": "^0.25.8",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kunlun-framework/kunlun-framework.git"
  },
  "bugs": {
    "url": "https://github.com/kunlun-framework/kunlun-framework/issues"
  },
  "homepage": "https://kunlun-framework.dev"
}
