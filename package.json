{
  "name": "kunlun-framework",
  "version": "1.0.0",
  "description": "昆仑框架 - 开源多智能体框架（OpenCLAW + Hermes + Claude Code整合）",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "docs": "typedoc src/index.ts --out docs",
    "prepare": "husky install"
  },
  "keywords": [
    "kunlun",
    "multi-agent",
    "openclaw",
    "hermes",
    "claude-code",
    "ai-framework",
    "multi-tenant",
    "skill-system",
    "memory-system"
  ],
  "author": "昆仑框架团队",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kunlun-framework/kunlun-framework.git"
  },
  "bugs": {
    "url": "https://github.com/kunlun-framework/kunlun-framework/issues"
  },
  "homepage": "https://kunlun-framework.dev"
}
