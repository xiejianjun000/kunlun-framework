# =========================================
# OpenTaiji 生产环境配置文件
# =========================================
# 注意: 此文件包含敏感信息，请勿提交到代码库

# =========================================
# 基础服务配置
# =========================================
NODE_ENV=production
LOG_LEVEL=info
APP_PORT=3000
API_PREFIX=/api/v1

# =========================================
# PostgreSQL 数据库配置
# =========================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=opentaiji
DB_PASSWORD=opentaiji_prod_secure_password_2026
DB_NAME=opentaiji_production
DB_SSL=false

# =========================================
# Redis 缓存与队列配置
# =========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=opentaiji_redis_secure_2026
REDIS_DB=0

# =========================================
# LLM 大模型适配器配置
# =========================================
# 统一接入地址
LLM_BASE_URL=http://your-llm-gateway-url:port/v1
LLM_API_KEY=your-llm-api-key-here
LLM_TIMEOUT=60000

# 默认模型
DEFAULT_LLM_MODEL=gpt-3.5-turbo

# =========================================
# 四大消息平台适配器配置
# =========================================

# 飞书 Feishu
FEISHU_ENABLED=true
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_VERIFICATION_TOKEN=your_verification_token
FEISHU_ENCRYPT_KEY=your_encrypt_key
FEISHU_WEBHOOK_PORT=3001

# 微信 WeChat
WECHAT_ENABLED=true
WECHAT_APP_ID=wx_xxxxxxxxxxxx
WECHAT_APP_SECRET=your_wechat_app_secret
WECHAT_TOKEN=your_wechat_token
WECHAT_ENCODING_AES_KEY=your_aes_key
WECHAT_WEBHOOK_PORT=3002

# 企业微信 WeCom
WECOM_ENABLED=true
WECOM_CORP_ID=ww_xxxxxxxxxxxx
WECOM_AGENT_ID=1000001
WECOM_SECRET=your_wecom_secret
WECOM_TOKEN=your_wecom_token
WECOM_ENCODING_AES_KEY=your_aes_key
WECOM_WEBHOOK_PORT=3003

# 钉钉 DingTalk
DINGTALK_ENABLED=true
DINGTALK_APP_KEY=ding_xxxxxxxxxxxx
DINGTALK_APP_SECRET=your_dingtalk_app_secret
DINGTALK_TOKEN=your_dingtalk_token
DINGTALK_ENCODING_AES_KEY=your_aes_key
DINGTALK_WEBHOOK_PORT=3004

# =========================================
# 监控配置
# =========================================
METRICS_ENABLED=true
METRICS_PORT=9091
METRICS_PATH=/metrics

# Prometheus 配置
PROMETHEUS_RETENTION_DAYS=30
PROMETHEUS_SCRAPE_INTERVAL=15s

# Grafana 配置
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=OpenTaiji@2026!

# =========================================
# 日志配置
# =========================================
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/opentaiji
LOG_MAX_SIZE=100MB
LOG_MAX_FILES=10
LOG_MAX_AGE=30d

# =========================================
# 安全配置
# =========================================
JWT_SECRET=opentaiji_jwt_secret_change_this_in_production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=*
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000

# =========================================
# 技能系统配置
# =========================================
SKILL_EXECUTION_TIMEOUT=120000
SKILL_MAX_CONCURRENCY=100
SKILL_CACHE_ENABLED=true
SKILL_WORKER_POOL_SIZE=16

# =========================================
# WFGY 防幻觉检测配置
# =========================================
WFGY_ENABLED=true
WFGY_THRESHOLD=0.85
WFGY_HALLUCINATION_DETECTION=true
WFGY_SOURCE_VERIFICATION=true
WFGY_CONSISTENCY_CHECK=true

# =========================================
# 成果调度器配置
# =========================================
SCHEDULER_ENABLED=true
SCHEDULER_MAX_JOBS=1000
SCHEDULER_RETRY_ATTEMPTS=3
SCHEDULER_RETRY_DELAY=5000

# =========================================
# 飞书推送结果配置
# =========================================
PUSH_FEISHU_ENABLED=false
PUSH_FEISHU_WEBHOOK=
PUSH_WECOM_ENABLED=false
PUSH_WECOM_WEBHOOK=
PUSH_DINGTALK_ENABLED=false
PUSH_DINGTALK_WEBHOOK=

# =========================================
# 健康检查配置
# =========================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s

# =========================================
# 生产环境特性开关
# =========================================
FEATURE_SKILL_SYSTEM=true
FEATURE_MEMORY_SYSTEM=true
FEATURE_MULTI_TENANT=true
FEATURE_HEARTBEAT=true
FEATURE_AUDIT_LOG=true
